{
  "name": "zxinnattapat-portfolio",
  "version": "1.0.0",
  "description": "Portfolio website with blog/articles for SEO",
  "scripts": {
    "build": "node build.js",
    "build:index": "node build.js --pages-only",
    "watch": "node build.js --watch",
    "watch:index": "node build.js --watch --pages-only",
    "dev": "node build.js --watch",
    "optimize-images": "node build.js --optimize-images",
    "build:all": "npm run optimize-images && npm run build"
  },
  "keywords": [
    "portfolio",
    "blog",
    "seo"
  ],
  "author": "Nattapat Phungphugdee",
  "license": "MIT",
  "devDependencies": {
    "marked": "^11.1.1",
    "front-matter": "^4.0.2",
    "sharp": "^0.33.0"
  }
}
